NODE_OPTIONS="--no-deprecation --no-experimental-strip-types"

# TayyibPay Payment Gateway
# Get these from your TayyibPay account at https://toyyibpay.com
# For sandbox/testing use https://dev.toyyibpay.com
TOYYIBPAY_SECRET_KEY=your_secret_key_here
TOYYIBPAY_CATEGORY_CODE=your_category_code_here
TOYYIBPAY_BASE_URL=https://toyyibpay.com
# Set to https://dev.toyyibpay.com for sandbox testing

# Public site URL (used for TayyibPay return/callback URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret for /api/process-pledges (use a long random string in production)
# Call: POST /api/process-pledges with Authorization: Bearer <CRON_SECRET>
# Schedule via Vercel Cron, cron-job.org, or any external scheduler
CRON_SECRET=your_cron_secret_here
