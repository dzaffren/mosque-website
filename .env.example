DATABASE_URL=file:./mosque.db
PAYLOAD_SECRET=your-secret-key-here

# Site URL (used in payment return/callback URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# TayyibPay credentials (https://toyyibpay.com)
TOYYIBPAY_BASE_URL=https://toyyibpay.com
TOYYIBPAY_SECRET_KEY=your-toyyibpay-secret-key
TOYYIBPAY_CATEGORY_CODE=your-category-code

# Cron job secret — used to secure /api/process-pledges
CRON_SECRET=a-long-random-secret

# Email notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL_TO=admin@your-mosque.com

# Production: Use Supabase PostgreSQL
# DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres
